<?xml version="1.0"?>
<launch>
  <node pkg="e2box_imu" type="e2box_imu_node" name="e2box_imu_node" output="screen">
    <param name="device" type="string" value="/dev/ttyUSB0" />
    <param name="baudrate" type="int" value="115200" />
    <param name="topic" type="string" value="/imu/data_raw" />
    <param name="frame" type="string" value="imu" />
  </node>
</launch>
